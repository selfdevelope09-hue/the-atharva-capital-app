# =============================================================================
# MODE A — Firebase-first (normal / fresh quota day) — DEFAULT
# =============================================================================
# Use these on Vercel + local production build so the app behaves like before:
# Firestore for users, trades, DMs, leaderboard reads where applicable.
#
# REACT_APP_USE_SUPABASE_DATA=false
# REACT_APP_USE_SUPABASE_TRADE=false
# (omit or false — do NOT set REACT_APP_SUPABASE_FALLBACK unless you want quota auto-switch)
#
# Keep server secrets on Vercel if you still deploy /api/* (harmless when modes above are false).

# =============================================================================
# MODE B — Supabase / BFF (quota day or migration) — enable tomorrow when needed
# =============================================================================
# REACT_APP_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
# REACT_APP_SUPABASE_ANON_KEY=YOUR_SUPABASE_ANON_KEY
# REACT_APP_USE_SUPABASE_DATA=true
# REACT_APP_USE_SUPABASE_TRADE=true
#
# Hybrid (recommended when Firestore read quota is tight):
# REACT_APP_USE_SUPABASE_DATA=false
# REACT_APP_USE_SUPABASE_TRADE=true
# Vercel must have: SUPABASE_URL, SUPABASE_SERVICE_ROLE_KEY, FIREBASE_SERVICE_ACCOUNT_JSON
# One-time: Supabase SQL Editor → supabase/trading_columns_migration.sql
# One-time: npm run migrate:firestore-users  (copy existing users into Supabase)
#
# Auto-switch session to BFF only after Firestore quota errors (requires deployed /api/*):
# REACT_APP_SUPABASE_FALLBACK=true

# Capacitor / split origin:
# REACT_APP_BFF_BASE_URL=https://your-app.vercel.app

# Local one-time DB migration (npm run db:migrate-trading):
# DATABASE_URL=postgresql://postgres.[PROJECT_REF]:[DB_PASSWORD]@....pooler.supabase.com:6543/postgres

# Vercel server (never commit real values):
# SUPABASE_URL=https://YOUR-PROJECT.supabase.co
# SUPABASE_SERVICE_ROLE_KEY=your_service_role_key
# FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account",...}
# BFF_CORS_ORIGINS=https://www.yourdomain.com
