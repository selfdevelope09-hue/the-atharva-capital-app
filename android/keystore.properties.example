# Copy to keystore.properties (never commit) and fill after you create the upload keystore.
# Create keystore (one time):
#   keytool -genkeypair -v -storetype PKCS12 -keystore auronx-upload.keystore -alias auronx -keyalg RSA -keysize 2048 -validity 10000
#
storePassword=your-store-password
keyPassword=your-key-password
keyAlias=auronx
storeFile=auronx-upload.keystore
