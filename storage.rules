rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    match /tip-charts/{userId}/{fileName} {
      allow read: if true;
      allow write: if request.auth != null
        && request.auth.uid == userId
        && request.resource.size < 5 * 1024 * 1024;
    }

    // Profile & showcase avatars: uploader writes only under their uid/ prefix; public read for display.
    match /profile-photos/{userId}/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null
        && request.auth.uid == userId
        && request.resource.size < 5 * 1024 * 1024
        && (!request.resource.contentType
          || request.resource.contentType.matches('image/.*'));
    }

    // DM photos: only authenticated user can write under their uid; thread id is part of path for organization.
    match /chat-media/{userId}/{threadId}/{fileName} {
      allow read: if true;
      allow write: if request.auth != null
        && request.auth.uid == userId
        && request.resource.size < 8 * 1024 * 1024
        && request.resource.contentType.matches('image/.*');
    }
  }
}
