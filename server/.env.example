# DigitalOcean — copy to .env on server (never commit real .env)
PORT=3000
NODE_ENV=production

# Postgres (TLS recommended)
PG_URL=postgresql://auronx:CHANGE_ME@127.0.0.1:5432/auronx?sslmode=require

# Firebase Admin — same JSON as Vercel FIREBASE_SERVICE_ACCOUNT_JSON
FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account",...}

# Optional: comma-separated blocked UIDs
BLOCKED_UIDS=

# CORS — production web + Capacitor
CORS_ORIGINS=https://www.theatharvacapital.com,https://theatharvacapital.com,https://localhost,capacitor://localhost

# Public URL for uploaded files (Vercel rewrites /uploads/* to this server)
PUBLIC_UPLOAD_BASE_URL=https://www.theatharvacapital.com
UPLOAD_DIR=/opt/auron-realtime/uploads

# AES-256-GCM key (32 bytes base64) for PII at rest if you encrypt email/phone columns
APP_DATA_ENC_KEY_B64=
