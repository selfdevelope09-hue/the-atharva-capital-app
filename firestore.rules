rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function stockTipEditorsDocExists() {
      return exists(/databases/$(database)/documents/config/stockTipEditors);
    }

    function stockTipsBootstrapMode() {
      return !stockTipEditorsDocExists();
    }

    // Keep in sync with PRIMARY_STOCK_TIP_OWNER_UID in src/stockTips/tipEditorUid.js
    function primaryStockTipOwnerUid() {
      return '8i1gWBZLj7NOdWTTj3Cg4sgCW4I2';
    }

    function isListedStockTipEditor() {
      return request.auth != null
        && stockTipEditorsDocExists()
        && get(/databases/$(database)/documents/config/stockTipEditors).data.keys().hasAll(['uids'])
        && (
          request.auth.uid in get(/databases/$(database)/documents/config/stockTipEditors).data.uids
          || request.auth.uid == primaryStockTipOwnerUid()
        );
    }

    function canPostStockTip() {
      return request.auth != null && (stockTipsBootstrapMode() || isListedStockTipEditor());
    }

    function isShowcaseUserId(userId) {
      return userId is string && userId.matches('^showcase__.+');
    }

    // Someone else updates only `followers` to add/remove their own uid (follow / unfollow).
    function followersOnlyUpdate(userId) {
      return request.auth != null
        && request.auth.uid != userId
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['followers'])
        && request.resource.data.followers is list;
    }

    // Editor-driven showcase follow updates (lets showcase profiles follow normal users).
    function showcaseFollowersOnlyUpdate(userId) {
      return request.auth != null
        && canPostStockTip()
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['followers'])
        && request.resource.data.followers is list;
    }

    function followAddsSelf() {
      return request.auth.uid in request.resource.data.followers
        && (!resource.data.keys().hasAny(['followers'])
            || !(request.auth.uid in resource.data.followers));
    }

    // Unfollow: remove self from their list. Also allow idempotent remove (heals client/server mismatch
    // where my `following` had them but their `followers` never got my uid).
    function followRemovesSelf() {
      return request.resource.data.followers is list
        && !(request.auth.uid in request.resource.data.followers)
        && (
          (resource.data.keys().hasAny(['followers'])
            && request.auth.uid in resource.data.followers)
          || (resource.data.keys().hasAny(['followers'])
            && request.resource.data.followers == resource.data.followers)
        );
    }

    match /users/{userId} {
      allow read: if true;

      allow create: if request.auth != null && (
        request.auth.uid == userId
        || (canPostStockTip()
            && isShowcaseUserId(userId)
            && request.resource.data.isShowcaseProfile == true
            && request.resource.data.name is string
            && request.resource.data.name.size() > 0
            && request.resource.data.name.size() < 120)
      );

      allow delete: if request.auth != null && (
        request.auth.uid == userId
        || (canPostStockTip() && isShowcaseUserId(userId))
      );

      allow update: if request.auth != null && (
        request.auth.uid == userId
        || (canPostStockTip() && isShowcaseUserId(userId))
        || (followersOnlyUpdate(userId) && (followAddsSelf() || followRemovesSelf()))
        || showcaseFollowersOnlyUpdate(userId)
      );
    }

    match /dmThreads/{threadId} {
      allow read, create, update: if request.auth != null;

      match /messages/{messageId} {
        allow read, create: if request.auth != null;
      }
    }

    match /config/stockTipEditors {
      allow read: if request.auth != null;
      allow write: if false;
    }

    match /config/blockedUsers {
      allow read: if request.auth != null;
      allow create, update: if isListedStockTipEditor();
      allow delete: if false;
    }

    match /stockTips/{tipId} {
      allow read: if true;
      allow create: if canPostStockTip()
        && request.resource.data.created_by == request.auth.uid;
      allow update, delete: if request.auth != null && (
        isListedStockTipEditor()
        || (stockTipsBootstrapMode() && resource.data.created_by == request.auth.uid)
      );
    }

    match /tipQueries/{queryId} {
      allow create: if request.auth != null
        && request.resource.data.user_uid == request.auth.uid;
      allow read: if canPostStockTip();
      allow update, delete: if false;
    }

    match /payments/{paymentId} {
      allow read: if request.auth != null && resource.data.user_uid == request.auth.uid;
      allow create, update, delete: if false;
    }

    function validLeaderboardShowcasePayload() {
      return request.resource.data.displayName is string
        && request.resource.data.displayName.size() > 0
        && request.resource.data.displayName.size() < 120
        && request.resource.data.pnl is number
        && (!request.resource.data.keys().hasAny(['tradeCount'])
          || (request.resource.data.tradeCount is int
              && request.resource.data.tradeCount >= 0
              && request.resource.data.tradeCount <= 500))
        && (!request.resource.data.keys().hasAny(['showcasePresenceOnline'])
          || request.resource.data.showcasePresenceOnline is bool)
        && (!request.resource.data.keys().hasAny(['showcasePresenceOfflineAt'])
          || request.resource.data.showcasePresenceOfflineAt == null
          || request.resource.data.showcasePresenceOfflineAt is timestamp);
    }

    match /leaderboardShowcase/{entryId} {
      allow read: if true;
      allow create: if canPostStockTip() && validLeaderboardShowcasePayload();
      allow update: if canPostStockTip() && validLeaderboardShowcasePayload();
      allow delete: if canPostStockTip();
    }

    // Mirror: user → showcase profile chat lines (admin reads in developer panel).
    match /adminChatLogs/{logId} {
      allow read: if canPostStockTip();
      allow create: if request.auth != null
        && request.resource.data.fromUid == request.auth.uid
        && request.resource.data.keys().hasAll(['peerShowcaseId', 'text'])
        && request.resource.data.peerShowcaseId is string
        && request.resource.data.peerShowcaseId.matches('^showcase__.+')
        && request.resource.data.text is string
        && request.resource.data.text.size() > 0
        && request.resource.data.text.size() < 4000;
      allow update, delete: if false;
    }
  }
}
